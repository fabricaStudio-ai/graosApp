{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and loyalty information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's full name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" },
        "role": { "type": "string", "enum": ["client", "manager"], "description": "User role" }
      },
      "required": ["email", "createdAt", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Store products including grain and supplements",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "numericPrice": { "type": "number" },
        "stock": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "tag": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "numericPrice", "category", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "icon", "color"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales orders",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["customerId", "date", "amount", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transactions",
      "type": "object",
      "properties": {
        "customer": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "method": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["date", "amount", "type", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Promotion coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "usage": { "type": "string" },
        "expires": { "type": "string" }
      },
      "required": ["code", "discount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales orders"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial history"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Promotional coupons"
    },
    "partners": {
      "schema": "Partner",
      "description": "Business partners"
    }
  }
}
